# ====================================================
# Accounting & Invoice Agent - Environment Variables
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env lên GitHub
# ====================================================

# --- LLM: Groq (primary) ---
# Lấy API key tại: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- LLM: Ollama (fallback - chạy local, không cần key) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Web Search: Tavily (primary) ---
# Lấy API key tại: https://app.tavily.com (free tier: 1000 searches/month)
TAVILY_API_KEY=your_tavily_api_key_here

# --- Vector Store: Chroma ---
# Local persist (dùng khi develop)
CHROMA_PERSIST_DIR=./data/chroma_db
# Set thành "memory" khi deploy lên Render/HF Spaces
CHROMA_MODE=persist

# --- Embedding Model (chạy local, không cần key) ---
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# --- App Settings ---
# LangGraph memory
LANGGRAPH_THREAD_ID=accounting-agent-thread
# Giới hạn agent loop (tránh infinite loop - R-02)
MAX_AGENT_ITERATIONS=10
# Faithfulness threshold để hiển thị disclaimer
FAITHFULNESS_THRESHOLD=0.75